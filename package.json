{
	"name": "beruang",
	"version": "0.1.0-beta",
	"private": true,
	"description": "Track money, transactions, and budgets. Per-user data with shortcodes and admin pages.",
	"license": "GPL-2.0-or-later",
	"devDependencies": {
		"eslint": "^8.57.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.4.3",
		"stylelint": "^16.0.0",
		"stylelint-config-standard": "^36.0.0"
	},
	"scripts": {
		"prepare": "husky",
		"lint": "npm run lint-php && npm run lint-js && npm run lint-css",
		"lint-php": "composer run lint",
		"lint-js": "eslint \"assets/js/*.js\"",
		"lint-css": "stylelint \"assets/css/*.css\"",
		"lint-fix": "npm run lint-fix-js && npm run lint-fix-css",
		"lint-fix-js": "eslint --fix \"assets/js/*.js\"",
		"lint-fix-css": "stylelint --fix \"assets/css/*.css\"",
		"zip": "version=$(node -p \"require('./package.json').version\") && cd .. && zip -r beruang.$version.zip beruang -x '*/.git/*' -x '*node_modules*' -x '*/vendor/*' -x '*/example-plugin/*'"
	},
	"lint-staged": {
		"*.php": ["./vendor/bin/phpcs -s --runtime-set testVersion 7.4- --runtime-set ignore_warnings_on_exit 0"],
		"assets/js/*.js": ["eslint --fix"],
		"assets/css/*.css": ["stylelint --fix"]
	}
}
