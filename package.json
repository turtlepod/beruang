{
  "name": "beruang",
  "version": "0.4.0-beta",
  "private": true,
  "description": "Track money, transactions, and budgets. Per-user data with shortcodes and admin pages.",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@10up/babel-preset-default": "^2.1.2",
    "@playwright/test": "^1.58.2",
    "10up-toolkit": "^6.5.1",
    "ajv": "^8.12.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.4.3",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "start": "npm run watch",
    "watch": "10up-toolkit watch --port=5010",
    "build": "npm run lint && 10up-toolkit build",
    "format-js": "10up-toolkit format-js",
    "lint": "npm run lint-php && npm run lint-js && npm run lint-css",
    "lint-php": "composer run lint",
    "lint-js": "eslint \"assets/js/*.js\" \"assets/js/frontend/*.js\"",
    "lint-css": "stylelint \"assets/css/**/*.css\"",
    "lint-fix": "npm run lint-fix-js && npm run lint-fix-css",
    "lint-fix-js": "eslint --fix \"assets/js/*.js\" \"assets/js/frontend/*.js\"",
    "lint-fix-css": "stylelint --fix \"assets/css/**/*.css\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "zip": "npm run build && composer run test && npx playwright test && version=$(node -p \"require('./package.json').version\") && cd .. && zip -r beruang.$version.zip beruang -x '*/.?*' -x '*node_modules*' -x '*/vendor/*'",
    "clean-dist": "rm -rf ./dist"
  },
  "10up-toolkit": {
    "entry": {
      "front": "./assets/js/beruang-front.js",
      "front-style": "./assets/css/beruang-front.css",
      "admin-style": "./assets/css/beruang-admin.css"
    }
  },
  "lint-staged": {
    "*.php": [
      "./vendor/bin/phpcs -s --runtime-set testVersion 8.2- --runtime-set ignore_warnings_on_exit 0"
    ],
    "assets/js/*.js": [
      "eslint --fix"
    ],
    "assets/js/frontend/*.js": [
      "eslint --fix"
    ],
    "assets/css/**/*.css": [
      "stylelint --fix"
    ]
  }
}
